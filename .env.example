# --------------------------------------------------
# Local test / local demo
# --------------------------------------------------
# Optional for local Hardhat demo. Defaults are used if left empty.
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
DEPLOY_MOCK_USDC=false
MOCK_USDC_NAME=Arc Test USDC
MOCK_USDC_SYMBOL=USDC

# --------------------------------------------------
# Arc deploy
# --------------------------------------------------
# Required for npm run deploy:arc
PRIVATE_KEY=
PLATFORM_WALLET=
DEPLOYMENT_OUTFILE=deployments/arcTestnet.latest.json

# --------------------------------------------------
# Verification
# --------------------------------------------------
ARCSCAN_API_KEY=arcscan
ARCSCAN_API_URL=https://testnet.arcscan.app/api
ARCSCAN_BROWSER_URL=https://testnet.arcscan.app

# --------------------------------------------------
# Relayer / indexer
# --------------------------------------------------
# Required for relayer:once and relayer:loop
RELAYER_PRIVATE_KEY=

# Manifest + state
DEPLOYMENT_MANIFEST_PATH=deployments/arcTestnet.latest.json
RELAYER_STATE_PATH=relayer-data/state.json

# Scan / renewal tuning
RENEWAL_SCAN_INTERVAL_SECONDS=60
INDEXER_CONFIRMATION_BLOCKS=3
RENEWAL_DUPLICATE_WINDOW_SECONDS=300
MAX_BLOCK_RANGE=5000
RENEWAL_GRACE_PERIOD_SECONDS=604800
START_BLOCK=
